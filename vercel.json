{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, GET, OPTIONS" },
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/poll-transcripts", "schedule": "*/5 * * * *" }
  ]
}
